          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#e15759' fontname='Lucida Bright'>HOURS</run>
            <run fontalignment='1'>Æ&#10;</run>
            <run bold='true' fontalignment='1' fontcolor='#ffffff' fontname='Lucida Bright'>Peak orders are</run>
