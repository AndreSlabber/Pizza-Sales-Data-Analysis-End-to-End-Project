            <run fontalignment='1'>Æ&#10;</run>
            <run bold='true' fontalignment='1' fontcolor='#ffffff' fontname='Lucida Bright'>the evening,</run>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Lucida Bright'>Æ </run>
            <run bold='true' fontalignment='1' fontcolor='#59a14f' fontname='Lucida Bright'>from 4:00 PM to </run>
            <run fontalignment='1'>Æ&#10;</run>
            <run bold='true' fontalignment='1' fontcolor='#59a14f' fontname='Lucida Bright'>7:00 PM</run>
            <run fontalignment='1'>Æ&#10;&#10;</run>
            <run bold='true' fontalignment='1' fontcolor='#4e79a7' fontname='Lucida Bright'>WEEKS</run>
            <run fontalignment='1'>Æ&#10;</run>
            <run bold='true' fontalignment='1' fontcolor='#ff9da7' fontname='Lucida Bright'>Significant variations in </run>
            <run fontalignment='1'>Æ&#10;</run>
            <run bold='true' fontalignment='1' fontcolor='#ff9da7' fontname='Lucida Bright'>weekly orders</run>
            <run bold='true' fontalignment='1' fontcolor='#ffffff' fontname='Lucida Bright'>, with highest </run>
