            <run bold='true' fontalignment='1' fontcolor='#f28e2b' fontname='Lucida Bright'>between</run>
            <run fontalignment='1'>Æ&#10;</run>
            <run bold='true' fontalignment='1' fontcolor='#f28e2b' fontname='Lucida Bright'>12:00 PM and 1:00</run>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Lucida Bright'>Æ </run>
            <run bold='true' fontalignment='1' fontcolor='#ffffff' fontname='Lucida Bright'>PM, and in</run>
